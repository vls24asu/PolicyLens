# ── Anthropic ──────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ── Neo4j ──────────────────────────────────────────────────────────────────────
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=changeme

# ── ChromaDB ──────────────────────────────────────────────────────────────────
# Use an absolute path or a path relative to the repo root.
CHROMA_PERSIST_DIR=./data/chroma

# ── Model selection ───────────────────────────────────────────────────────────
VLM_MODEL=claude-sonnet-4-6

# ── Application ───────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
API_HOST=0.0.0.0
API_PORT=8000
